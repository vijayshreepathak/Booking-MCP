# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appointment_db

# LLM Provider: demo | openai | anthropic | local
LLM_PROVIDER=demo

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local LLM (when LLM_PROVIDER=local, e.g. Ollama)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_MODEL=llama2

# Backend base URL (for MCP call_url)
BASE_URL=http://localhost:8000

# Google Calendar (optional - demo mode if not set)
GOOGLE_CALENDAR_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_CALENDAR_ID=primary

# SendGrid (optional - demo mode if not set)
SENDGRID_API_KEY=SG.your-sendgrid-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Slack (optional - in-app notification if not set)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
